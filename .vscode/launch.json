{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "pytest: unit tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/unit",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "${config:python.defaultInterpreterPath}",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "pytest: smoke tests (CUDA)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/smoke",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "${config:python.defaultInterpreterPath}",
            "cwd": "${workspaceFolder}"
        }
    ]
}
