{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "pytest: unit tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/unit",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "/opt/homebrew/opt/python@3.11/bin/python3.11",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "pytest: smoke tests (MPS / CUDA)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/smoke",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "/opt/homebrew/opt/python@3.11/bin/python3.11",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTORCH_ENABLE_MPS_FALLBACK": "1"
            }
        }
    ]
}
